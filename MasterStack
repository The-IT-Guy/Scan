function Invoke-PrintFix {
    Write-Host "Resetting Print Spooler..." -ForegroundColor Yellow
    Stop-Service -Name Spooler -Force
    Remove-Item -Path "$env:windir\System32\spool\PRINTERS\*.*" -Force -Recurse -ErrorAction SilentlyContinue
    Start-Service -Name Spooler
    $Printers = Get-CimInstance Win32_Printer | Select-Object Name, PortName, DriverName | ConvertTo-Html -Fragment
    $Log = "<div class='log-box'>> Stopping Spooler... SUCCESS<br>> Clearing jobs... SUCCESS<br>> Restarting Spooler... SUCCESS</div><h2>Installed Printers Detected</h2>$Printers"
    New-HtmlReport -Title "Print Spooler Reset" -Content $Log
}

