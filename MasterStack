function New-HtmlReport {
    param([string]$Title, [string]$Content)
    $ReportPath = "$env:TEMP\$($Title -replace '[^a-zA-Z0-9]','').html"
    $Date = Get-Date -Format "dddd, MMMM dd, yyyy 'at' hh:mm tt"
    
    $HTML = @"
    <!DOCTYPE html><html><head><title>$Title</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background-color: #0d0d0d; color: #e0e0e0; padding: 40px; }
        .container { max-width: 1100px; margin: auto; background: #181818; padding: 35px; border-radius: 12px; border: 1px solid #333; box-shadow: 0 15px 40px rgba(0,0,0,0.8); }
        h1 { color: #00d4ff; border-bottom: 2px solid #00d4ff; padding-bottom: 15px; font-weight: 200; }
        h2 { color: #ff9100; margin-top: 30px; border-left: 4px solid #ff9100; padding-left: 15px; font-size: 1.3em; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; background: #222; font-size: 0.9em; }
        th { text-align: left; background: #2d2d2d; padding: 12px; color: #00d4ff; border-bottom: 2px solid #444; }
        td { padding: 10px; border-bottom: 1px solid #333; }
        tr:nth-child(even) { background: #1c1c1c; }
        .log-box { font-family: 'Consolas', monospace; background: #000; color: #00ff41; padding: 20px; border-radius: 6px; border: 1px solid #444; line-height: 1.5; margin-top: 20px; overflow-x: auto; }
        .metric-high { color: #ff5252; font-weight: bold; }
    </style>
    </head><body><div class="container"><h1>$Title</h1><p style="color:#666;">Diagnostic Engine v6.0 | $Date</p>$Content</div></body></html>
"@
    $HTML | Out-File $ReportPath -Encoding utf8 -Force
    Invoke-Item $ReportPath
}

