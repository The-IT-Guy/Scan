function Invoke-SysHealth {
    Write-Host "Gathering System Health Data..." -ForegroundColor Green
    $OS = Get-CimInstance Win32_OperatingSystem
    $OSName = $OS.Caption -replace 'Microsoft ', ''
    $Uptime = (Get-Date) - $OS.LastBootUpTime
    $UptimeStr = "$($Uptime.Days) Days, $($Uptime.Hours) Hours, $($Uptime.Minutes) Minutes"
    
    $CPU = Get-CimInstance Win32_Processor | Measure-Object -Property LoadPercentage -Average | Select-Object -ExpandProperty Average
    $RAMUsage = [math]::Round((($OS.TotalVisibleMemorySize - $OS.FreePhysicalMemory) / $OS.TotalVisibleMemorySize) * 100, 1)

    $PerfHTML = "<h2>Live Performance & Uptime</h2><table><tr><th>Metric</th><th>Status</th></tr><tr><td>System Uptime</td><td>$UptimeStr</td></tr><tr><td>Current CPU Usage</td><td>$CPU%</td></tr><tr><td>Current RAM Usage</td><td>$RAMUsage%</td></tr></table>"

    $SysDrive = $env:SystemDrive
    $Disks = Get-CimInstance Win32_LogicalDisk -Filter "DriveType=3" | Select-Object `
        @{Name="Drive";Expression={ if ($_.DeviceID -eq $SysDrive) { "$($_.DeviceID) ($OSName)" } else { $_.DeviceID } }}, 
        @{Name="Free Space (GB)";Expression={[math]::round($_.FreeSpace / 1GB,2)}},
        @{Name="Total Size (GB)";Expression={[math]::round($_.Size / 1GB,2)}}
    
    $DiskHTML = "<h2>Storage Drives</h2>" + ($Disks | ConvertTo-Html -Fragment)
    New-HtmlReport -Title "System Health Report" -Content ($PerfHTML + $DiskHTML)
}

function Invoke-NetworkReset {
    Write-Host "Resetting Network Stack. Please wait..." -ForegroundColor Yellow
    ipconfig /release | Out-Null; ipconfig /flushdns | Out-Null; ipconfig /renew | Out-Null; netsh winsock reset | Out-Null
    Write-Host "Testing Internet Connectivity..." -ForegroundColor Cyan
    $Ping = Test-Connection -ComputerName "8.8.8.8" -Count 2 -Quiet
    $PingStatus = if ($Ping) { "<span style='color:#4CAF50;'>SUCCESS (Internet Connected)</span>" } else { "<span style='color:#F44336;'>FAILED (No Internet)</span>" }
    $Log = "<div class='log-box'>> Releasing IP Address... SUCCESS<br>> Flushing DNS Cache... SUCCESS<br>> Renewing IP Address... SUCCESS<br>> Resetting Winsock Catalog... SUCCESS<br>> Pinging Google DNS (8.8.8.8)... $PingStatus</div>"
    New-HtmlReport -Title "Network Reset Log" -Content $Log
}

function Invoke-Cleanup {
    Write-Host "Cleaning Temp Files and Caches..." -ForegroundColor Yellow
    $TempPath = $env:TEMP
    Remove-Item "$TempPath\*" -Recurse -Force -ErrorAction SilentlyContinue
    Clear-RecycleBin -Force -ErrorAction SilentlyContinue
    Remove-Item "C:\ProgramData\Microsoft\Windows\WER\ReportArchive\*" -Recurse -Force -ErrorAction SilentlyContinue
    $Log = "<div class='log-box'>> Emptying Recycle Bin... SUCCESS<br>> Removing User Temporary Files... SUCCESS<br>> Clearing Windows Error Reporting logs... SUCCESS<br>> System cleanup complete.</div>"
    New-HtmlReport -Title "Cleanup Report" -Content $Log
}

function Invoke-RepairSystem {
    Write-Host "`n--- REPAIRING WINDOWS SYSTEM ---" -ForegroundColor Yellow
    Write-Host "1/3: Running Live CheckDisk (CHKDSK)..." -ForegroundColor White; chkdsk $env:SystemDrive /scan
    Write-Host "2/3: Running DISM RestoreHealth..." -ForegroundColor White; Repair-WindowsImage -Online -RestoreHealth
    Write-Host "3/3: Running SFC Scannow..." -ForegroundColor White; sfc /scannow
    $Log = "<div class='log-box'>> CHKDSK /Scan ... COMPLETED<br>> DISM /RestoreHealth ... COMPLETED<br>> SFC /Scannow ... COMPLETED<br><br>File system and Windows Image checked and repaired.</div>"
    New-HtmlReport -Title "Windows Repair Log" -Content $Log
}

