do {
    Show-Menu
    $choice = Read-Host "Select an option (1-15)"
    
    switch ($choice) {
        '1' { Invoke-SysHealth }
        '2' { Invoke-FullAuditReport }
        '3' { Invoke-CrashDiagnostics }
        '4' { Invoke-StartupAnalyzer }
        '5' { Invoke-HardwareInfo }
        '6' { Invoke-BatteryReport }
        '7' { Invoke-WiFiExtractor }
        '8' { Invoke-SystemRestorePoint }
        '9' { Invoke-RepairSystem }
        '10' { Invoke-Cleanup }
        '11' { Invoke-NetworkReset }
        '12' { Invoke-PrintFix }
        '13' { Invoke-SecurityCheck }
        '14' { Invoke-SoftwareUpdateCheck }
        '15' { Write-Host "Exiting..." -ForegroundColor Yellow }
