# --- [DIAGNOSTICS] ---

function Invoke-UltimateAudit {
    $OS = Get-CimInstance Win32_OperatingSystem
    $Software = Get-ItemProperty HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\* | Select-Object DisplayName, DisplayVersion | Where-Object { $_.DisplayName -ne $null } | Select-Object -First 25
    $AuditHTML = "<h2>System Overview</h2><table><tr><td>OS Name</td><td>$($OS.Caption)</td></tr><tr><td>Install Date</td><td>$($OS.InstallDate)</td></tr></table>"
    $SoftHTML = "<h2>Application Audit (Top 25)</h2>" + ($Software | ConvertTo-Html -Fragment)
    New-HtmlReport -Title "Ultimate System Audit" -Content ($AuditHTML + $SoftHTML)
}

function Invoke-SysHealth {
    $OS = Get-CimInstance Win32_OperatingSystem
    $Disk = Get-PhysicalDisk | Select-Object DeviceID, FriendlyName, MediaType, HealthStatus, Temperature
    $Procs = Get-Process | Sort-Object CPU -Descending | Select-Object -First 10 | Select-Object Name, CPU, @{Name="RAM(MB)";Expression={[math]::Round($_.WorkingSet64/1MB,2)}}
    $StatsHTML = "<h2>Deep Health Stats</h2><table><tr><td>Available RAM</td><td>$([math]::Round($OS.FreePhysicalMemory / 1MB, 2)) GB Free</td></tr><tr><td>System Uptime</td><td>$((Get-Date) - $OS.LastBootUpTime)</td></tr></table>"
    $DiskHTML = "<h2>Drive Health (SMART)</h2>" + ($Disk | ConvertTo-Html -Fragment)
    $ProcHTML = "<h2>Top Resource Consumers</h2>" + ($Procs | ConvertTo-Html -Fragment)
    New-HtmlReport -Title "Deep Health Audit" -Content ($StatsHTML + $DiskHTML + $ProcHTML)
}

function Invoke-EventDeepDive {
    $Events = Get-WinEvent -FilterHashtable @{LogName='System'; Level=1,2; StartTime=(Get-Date).AddDays(-7)} -MaxEvents 20 -ErrorAction SilentlyContinue
    $HTML = "<h2>Critical Events (Last 7 Days)</h2>"
    if ($Events) { $HTML += ($Events | Select-Object TimeCreated, ProviderName, Message | ConvertTo-Html -Fragment) }
    else { $HTML += "<p>No critical OS errors found.</p>" }
    New-HtmlReport -Title "Event Log Monitor" -Content $HTML
}

function Invoke-HardwareInfo {
    $Bios = Get-CimInstance Win32_BIOS; $Cpu = Get-CimInstance Win32_Processor
    $Ram = Get-CimInstance Win32_PhysicalMemory | Select-Object DeviceLocator, Speed, Manufacturer, PartNumber
    $HwHTML = "<h2>Core Architecture</h2><table><tr><td>Processor</td><td>$($Cpu.Name)</td></tr><tr><td>Serial Number</td><td style='color:#00d4ff;'>$($Bios.SerialNumber)</td></tr></table>"
    $RamHTML = "<h2>RAM Part Details</h2>" + ($Ram | ConvertTo-Html -Fragment)
    New-HtmlReport -Title "Hardware Inventory" -Content ($HwHTML + $RamHTML)
}

function Invoke-BatteryReport {
    powercfg /batteryreport /output "$env:TEMP\BatteryReport.html" | Out-Null
    Invoke-Item "$env:TEMP\BatteryReport.html"
}

# --- [MAINTENANCE & REPAIR] ---

function Invoke-RepairSystem {
    [System.Windows.Forms.MessageBox]::Show("Starting DISM and SFC repair. This may take 5-10 minutes. The report will open automatically when finished.", "Repair in Progress")
    $Dism = Repair-WindowsImage -Online -RestoreHealth
    $Sfc = sfc /scannow | Out-String
    New-HtmlReport -Title "Repair Log" -Content "<div class='log-box'><h3>DISM /RestoreHealth:</h3>$($Dism.ImageHealthState)<br><h3>SFC /Scannow:</h3>$Sfc</div>"
}

function Invoke-WindowsDebloat {
    $Apps = @("*FeedbackHub*", "*3dviewer*", "*MixedReality*", "*Print3D*")
    $log = "<div class='log-box'>"
    foreach ($app in $Apps) { 
        Get-AppxPackage -Name $app | Remove-AppxPackage -ErrorAction SilentlyContinue
        $log += "[+] Removed: $app<br>" 
    }
    $log += "Debloat Complete.</div>"
    New-HtmlReport -Title "Debloat Report" -Content $log
}

function Invoke-Cleanup {
    Clear-RecycleBin -Force -ErrorAction SilentlyContinue
    Remove-Item "$env:TEMP\*" -Recurse -Force -ErrorAction SilentlyContinue
    New-HtmlReport -Title "Cleanup Report" -Content "<div class='log-box'>Temporary files and Recycle Bin purged.</div>"
}

function Invoke-UpdateFixer {
    $Services = @("wuauserv", "bits", "cryptsvc")
    foreach ($s in $Services) { Stop-Service $s -Force -ErrorAction SilentlyContinue }
    Remove-Item "C:\Windows\SoftwareDistribution" -Recurse -Force -ErrorAction SilentlyContinue
    foreach ($s in $Services) { Start-Service $s -ErrorAction SilentlyContinue }
    $History = Get-CimInstance -Query "SELECT * FROM Win32_QuickFixEngineering" | Sort-Object InstalledOn -Descending | Select-Object -First 5
    New-HtmlReport -Title "Update Fix Log" -Content ("<div class='log-box'>Update Agent Reset Successfully. SoftwareDistribution Cache Purged.</div><h2>Patch History (Last 5)</h2>" + ($History | ConvertTo-Html -Fragment))
}

function Invoke-PrintFix {
    Stop-Service Spooler -Force -ErrorAction SilentlyContinue
    Start-Service Spooler -ErrorAction SilentlyContinue
    New-HtmlReport -Title "Print Spooler Reset" -Content "<div class='log-box'>Spooler service cycled successfully.</div>"
}

# --- [SECURITY & CONNECTIVITY] ---

function Invoke-SecurityAudit {
    $AV = Get-CimInstance -Namespace root/SecurityCenter2 -ClassName AntiVirusProduct -ErrorAction SilentlyContinue
    $BL = Get-BitLockerVolume -MountPoint "C:" -ErrorAction SilentlyContinue
    $FW = Get-NetFirewallProfile -Profile Domain,Public,Private | Select-Object Name, Enabled
    $HTML = "<h2>Security Status</h2><table><tr><td>AV Engine</td><td>$($AV.displayName)</td></tr><tr><td>BitLocker (C:)</td><td>$($BL.ProtectionStatus) ($($BL.EncryptionMethod))</td></tr></table>"
    $FwHTML = "<h2>Firewall Profiles</h2>" + ($FW | ConvertTo-Html -Fragment)
    New-HtmlReport -Title "Security Deep Audit" -Content ($HTML + $FwHTML)
}

function Invoke-WiFiExtractor {
    $Profiles = netsh wlan show profiles | Select-String "All User Profile" | Foreach { ($_.Line -split ": ")[1] }
    $Table = "<h2>WiFi Recovery</h2><table>"
    foreach ($p in $Profiles) { 
        $Key = netsh wlan show profile name="$p" key=clear | Select-String "Key Content" | Foreach { ($_.Line -split ": ")[1] }
        if (-not $Key) { $Key = "OPEN / No Password" }
        $Table += "<tr><td>$p</td><td>$Key</td></tr>" 
    }
    New-HtmlReport -Title "WiFi Recovery" -Content ($Table + "</table>")
}

function Invoke-NetworkReset {
    # 1. CREATE SELECTION POPUP (Bulletproof Scope)
    $DNSForm = New-Object System.Windows.Forms.Form
    $DNSForm.Text = "Select DNS"
    $DNSForm.Size = "300, 250"
    $DNSForm.BackColor = [System.Drawing.Color]::FromArgb(35, 35, 35)
    $DNSForm.StartPosition = "CenterScreen"
    $DNSForm.FormBorderStyle = "FixedDialog"
    $DNSForm.MaximizeBox = $false
    $DNSForm.TopMost = $true # Forces the popup to stay in front!
    
    $Label = New-Object System.Windows.Forms.Label
    $Label.Text = "Choose a DNS for this repair:"
    $Label.ForeColor = [System.Drawing.Color]::White
    $Label.Location = "20, 20"
    $Label.Size = "260, 20"
    $DNSForm.Controls.Add($Label)

    $script:dnsChoice = "None"
    
    $btn1 = New-Object System.Windows.Forms.Button
    $btn1.Text = "Google (8.8.8.8)"; $btn1.Location = "20, 50"; $btn1.Size = "240, 35"; $btn1.FlatStyle = "Flat"; $btn1.ForeColor = [System.Drawing.Color]::Gold
    $btn1.Add_Click({ $script:dnsChoice = "Google"; $DNSForm.Close() })
    
    $btn2 = New-Object System.Windows.Forms.Button
    $btn2.Text = "Cloudflare (1.1.1.1)"; $btn2.Location = "20, 95"; $btn2.Size = "240, 35"; $btn2.FlatStyle = "Flat"; $btn2.ForeColor = [System.Drawing.Color]::Cyan
    $btn2.Add_Click({ $script:dnsChoice = "Cloudflare"; $DNSForm.Close() })
    
    $btn3 = New-Object System.Windows.Forms.Button
    $btn3.Text = "System Default (DHCP)"; $btn3.Location = "20, 140"; $btn3.Size = "240, 35"; $btn3.FlatStyle = "Flat"; $btn3.ForeColor = [System.Drawing.Color]::White
    $btn3.Add_Click({ $script:dnsChoice = "Default"; $DNSForm.Close() })

    $DNSForm.Controls.Add($btn1)
    $DNSForm.Controls.Add($btn2)
    $DNSForm.Controls.Add($btn3)
    
    $DNSForm.ShowDialog() | Out-Null
    
    if ($script:dnsChoice -eq "None") { return }

    # 2. RUN THE REPAIR
    $Log = "<div class='log-box'>[!] RESETTING NETWORK...<br>[+] Choice: $script:dnsChoice<br>"
    ipconfig /flushdns | Out-Null; netsh winsock reset | Out-Null; netsh int ip reset | Out-Null
    
    $Adapters = Get-NetAdapter | Where-Object { $_.Status -eq "Up" }
    foreach ($Adapter in $Adapters) {
        if ($script:dnsChoice -eq "Google") { 
            Set-DnsClientServerAddress -InterfaceAlias $Adapter.InterfaceAlias -ServerAddresses ("8.8.8.8","8.8.4.4") -ErrorAction SilentlyContinue 
        } elseif ($script:dnsChoice -eq "Cloudflare") { 
            Set-DnsClientServerAddress -InterfaceAlias $Adapter.InterfaceAlias -ServerAddresses ("1.1.1.1","1.0.0.1") -ErrorAction SilentlyContinue 
        } elseif ($script:dnsChoice -eq "Default") { 
            Set-DnsClientServerAddress -InterfaceAlias $Adapter.InterfaceAlias -ResetServerAddresses -ErrorAction SilentlyContinue 
        }
        $Log += "[+] DNS applied to: $($Adapter.InterfaceAlias)<br>"
    }
    
    ipconfig /release | Out-Null; ipconfig /renew | Out-Null
    
    $Ping = Test-Connection -ComputerName 8.8.8.8 -Count 1 -Quiet
    $Log += "[*] Internet Test: $(if ($Ping) { 'Online' } else { 'Offline' })<br>[SUCCESS] Stack Refreshed.</div>"
    
    $Results = Get-DnsClientServerAddress -AddressFamily IPv4 | Select-Object InterfaceAlias, ServerAddresses
    New-HtmlReport -Title "Network & DNS Reset" -Content ($Log + "<h2>Final Config</h2>" + ($Results | ConvertTo-Html -Fragment))
}

