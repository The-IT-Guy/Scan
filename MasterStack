function Invoke-SecurityCheck {
    Write-Host "Checking Security, Firewall & BitLocker..." -ForegroundColor Cyan
    
    # BitLocker Check
    $BLHTML = "<h2>Drive Encryption (BitLocker)</h2>"
    try {
        $BL = Get-BitLockerVolume -MountPoint $env:SystemDrive -ErrorAction Stop
        $BLStatus = if ($BL.VolumeStatus -eq 'FullyDecrypted') { "<span style='color:#F44336; font-weight:bold;'>Decrypted (Protection OFF)</span>" } else { "<span style='color:#4CAF50; font-weight:bold;'>$($BL.VolumeStatus)</span>" }
        $BLHTML += "<table><tr><th>Drive</th><th>Encryption Status</th><th>Protection Method</th></tr><tr><td>$($BL.MountPoint)</td><td>$BLStatus</td><td>$($BL.EncryptionMethod)</td></tr></table>"
    } catch {
        $BLHTML += "<p style='color:#FF9800;'>BitLocker is not supported or not available on this Windows edition (Home).</p>"
    }

    # Firewall Status
    $FWProfiles = Get-NetFirewallProfile | Select-Object Name, Enabled
    $FWHTML = "<h2>Windows Firewall Status</h2><table><tr><th>Profile</th><th>Status</th></tr>"
    foreach ($fw in $FWProfiles) {
        $StatusText = if ($fw.Enabled -eq $true) { "<span style='color:#4CAF50; font-weight:bold;'>ON</span>" } else { "<span style='color:#F44336; font-weight:bold;'>OFF</span>" }
        $FWHTML += "<tr><td>$($fw.Name)</td><td>$StatusText</td></tr>"
    }
    $FWHTML += "</table>"

    # Antivirus Status
    $AVProducts = Get-CimInstance -Namespace root/SecurityCenter2 -ClassName AntiVirusProduct -ErrorAction SilentlyContinue
    $AVHTML = "<h2>Antivirus Security</h2>"
    if ($AVProducts) {
        $AVHTML += "<table><tr><th>Antivirus Name</th><th>Protection Status</th><th>Signatures</th></tr>"
        foreach ($av in $AVProducts) {
            $State = $av.productState
            $IsEnabled = ($State -band 0xF000) -eq 0x1000
            $IsUpToDate = ($State -band 0x00F0) -eq 0
            $StatusText = if ($IsEnabled) { "<span style='color:#4CAF50; font-weight:bold;'>Enabled</span>" } else { "<span style='color:#F44336; font-weight:bold;'>Disabled</span>" }
            $UpdateText = if ($IsUpToDate) { "<span style='color:#4CAF50; font-weight:bold;'>Up to Date</span>" } else { "<span style='color:#FF9800; font-weight:bold;'>Outdated</span>" }
            $AVHTML += "<tr><td>$($av.displayName)</td><td>$StatusText</td><td>$UpdateText</td></tr>"
        }
        $AVHTML += "</table>"
    } else { $AVHTML += "<p style='color:#F44336;'>No Antivirus products registered in Windows Security Center.</p>" }
    
    New-HtmlReport -Title "Security Software Report" -Content ($BLHTML + $FWHTML + $AVHTML)
}

function Invoke-SoftwareUpdateCheck {
    Write-Host "Scanning for outdated software using Winget... (This may take a minute)" -ForegroundColor Cyan
    $env:WINGET_DISABLE_PROGRESS_BAR = 1 
    try {
        $upgradeData = winget upgrade --accept-source-agreements | Out-String
        if ($upgradeData -match "No installed package found" -or $upgradeData -match "No applicable update") {
            $HTML = "<h2>Software Updates</h2><p><span style='color:#4CAF50; font-weight:bold;'>All managed software is up to date!</span></p>"
        } elseif ($upgradeData -match "Name") {
            $cleanData = $upgradeData -replace "(?s).*?(Name\s+Id\s+Version)","`$1"
            $HTML = "<h2>Available Software Updates</h2><pre class='log-box'>$cleanData</pre>"
        } else { $HTML = "<h2>Software Updates</h2><pre class='log-box'>$upgradeData</pre>" }
    } catch { $HTML = "<h2>Software Updates</h2><p style='color:#F44336;'>Windows Package Manager (Winget) is not installed.</p>" }
    New-HtmlReport -Title "Outdated Software Check" -Content $HTML
}

function Invoke-StartupAnalyzer {
    Write-Host "Analyzing Startup Programs..." -ForegroundColor Cyan
    $StartupItems = @()
    
    # Collect from Registry HKLM
    $HKLM = Get-ItemProperty "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
    if ($HKLM) { foreach ($prop in $HKLM.psobject.properties | Where-Object { $_.Name -notin "PSPath","PSParentPath","PSChildName","PSDrive","PSProvider" }) { $StartupItems += [PSCustomObject]@{Source="Registry (All Users)"; Name=$prop.Name; Command=$prop.Value} } }
    
    # Collect from Registry HKCU
    $HKCU = Get-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
    if ($HKCU) { foreach ($prop in $HKCU.psobject.properties | Where-Object { $_.Name -notin "PSPath","PSParentPath","PSChildName","PSDrive","PSProvider" }) { $StartupItems += [PSCustomObject]@{Source="Registry (Current User)"; Name=$prop.Name; Command=$prop.Value} } }
    
    $HTML = "<h2>Startup Programs (Slow Boot Analyzer)</h2>"
    if ($StartupItems.Count -gt 0) {
        $HTML += "<table><tr><th>App Name</th><th>Command / Path</th><th>Source Location</th></tr>"
        foreach ($item in $StartupItems) { $HTML += "<tr><td style='font-weight:bold;'>$($item.Name)</td><td>$($item.Command)</td><td>$($item.Source)</td></tr>" }
        $HTML += "</table>"
    } else { $HTML += "<p>No third-party startup apps detected in the standard registry locations.</p>" }
    
    New-HtmlReport -Title "Startup Analyzer" -Content $HTML
}

function Invoke-CrashDiagnostics {
    Write-Host "Searching Event Logs for Recent System Crashes..." -ForegroundColor Cyan
    # Get Critical (Level 1) or Error (Level 2) from System log in last 30 days
    $Events = Get-WinEvent -FilterHashtable @{LogName='System'; Level=1,2; StartTime=(Get-Date).AddDays(-30)} -MaxEvents 15 -ErrorAction SilentlyContinue | Where-Object { $_.ProviderName -match "BugCheck|Kernel-Power|WER" }
    
    $HTML = "<h2>Crash Diagnostics (Last 30 Days)</h2>"
    if ($Events) {
        $HTML += "<table><tr><th>Date & Time</th><th>Event ID</th><th>Source</th><th>Description / Error Code</th></tr>"
        foreach ($e in $Events) { $HTML += "<tr><td>$($e.TimeCreated)</td><td style='color:#F44336; font-weight:bold;'>$($e.Id)</td><td>$($e.ProviderName)</td><td>$($e.Message)</td></tr>" }
        $HTML += "</table><p style='font-size:10pt; color:#888;'><em>Note: Kernel-Power Event 41 indicates an unexpected shutdown (power loss or hard freeze). BugCheck indicates a Blue Screen.</em></p>"
    } else { $HTML += "<p><span style='color:#4CAF50; font-weight:bold;'>Excellent:</span> No critical crashes or Blue Screens detected in the System event log in the last 30 days.</p>" }
    
    New-HtmlReport -Title "Crash Diagnostics Log" -Content $HTML
}

function Invoke-SystemRestorePoint {
    Write-Host "Creating System Restore Point..." -ForegroundColor Yellow
    Write-Host "Please wait, this can take a minute..." -ForegroundColor White
    
    try {
        Enable-ComputerRestore -Drive "$env:SystemDrive\" -ErrorAction SilentlyContinue
        Checkpoint-Computer -Description "MasterStack Pre-Maintenance Backup" -RestorePointType "MODIFY_SETTINGS" -ErrorAction Stop
        $Log = "<div class='log-box'>> Enabling System Restore on Drive C:... SUCCESS<br>> Creating Restore Point ('MasterStack Pre-Maintenance Backup')... SUCCESS<br><br><span style='color:#4CAF50;'>You now have a safe rollback point.</span></div>"
    } catch {
        $Log = "<div class='log-box' style='color:#F44336;'>> FAILED to create restore point.<br>> Error: $($_.Exception.Message)<br><br>System Restore might be disabled by Group Policy or space limits.</div>"
    }
    New-HtmlReport -Title "System Restore Point Creation" -Content $Log
}

function Invoke-WiFiExtractor {
    Write-Host "Extracting Saved Wi-Fi Passwords..." -ForegroundColor Cyan
    $Profiles = netsh wlan show profiles | Select-String -Pattern "All User Profile" | Foreach-Object { ($_.Line -split ": ")[1] }
    
    $HTML = "<h2>Saved Wi-Fi Profiles & Passwords</h2>"
    if ($Profiles) {
        $HTML += "<table><tr><th>Wi-Fi Network Name (SSID)</th><th>Saved Password (Cleartext)</th></tr>"
        foreach ($prof in $Profiles) {
            $Key = netsh wlan show profile name="$prof" key=clear | Select-String -Pattern "Key Content" | Foreach-Object { ($_.Line -split ": ")[1] }
            if (-not $Key) { $Key = "<span style='color:#888;'>[Open Network / No Password]</span>" }
            $HTML += "<tr><td style='font-weight:bold;'>$prof</td><td style='color:#4CAF50; font-family:Consolas, monospace;'>$Key</td></tr>"
        }
        $HTML += "</table>"
    } else { $HTML += "<p style='color:#FF9800;'>No saved Wi-Fi networks found, or PC does not have a Wi-Fi adapter.</p>" }
    
    New-HtmlReport -Title "Wi-Fi Password Extractor" -Content $HTML
}

function Invoke-FullAuditReport {
    Write-Host "Gathering Ultimate System Audit... Please wait." -ForegroundColor Cyan
    
    # 1. OS & Uptime
    $OS = Get-CimInstance Win32_OperatingSystem
    $OSName = $OS.Caption -replace 'Microsoft ', ''
    $Uptime = (Get-Date) - $OS.LastBootUpTime
    $UptimeStr = "$($Uptime.Days) Days, $($Uptime.Hours) Hours, $($Uptime.Minutes) Minutes"
    $FullContent = "<h2>Operating System</h2><table><tr><th>Property</th><th>Value</th></tr><tr><td>OS Name</td><td>$OSName</td></tr><tr><td>Version</td><td>$($OS.Version)</td></tr><tr><td>Install Date</td><td>$($OS.InstallDate)</td></tr><tr><td>System Uptime</td><td>$UptimeStr</td></tr></table>"

    # 2. Hardware
    $System = Get-CimInstance Win32_ComputerSystem; $BIOS = Get-CimInstance Win32_BIOS; $CPU = Get-CimInstance Win32_Processor
    $Board = Get-CimInstance Win32_BaseBoard; $GPU = Get-CimInstance Win32_VideoController
    $RAM = "$([math]::Round($System.TotalPhysicalMemory / 1GB, 2)) GB"; $GPUName = if ($GPU.Count -gt 1) { ($GPU.Name) -join ", " } else { $GPU.Name }
    $FullContent += "<h2>Hardware Specifications</h2><table><tr><th>Component</th><th>Details</th></tr><tr><td>Manufacturer</td><td>$($System.Manufacturer)</td></tr><tr><td>Model</td><td>$($System.Model)</td></tr><tr><td>Motherboard</td><td>$($Board.Manufacturer) $($Board.Product)</td></tr><tr><td>Serial Number</td><td style='color:#4CAF50; font-weight:bold;'>$($BIOS.SerialNumber)</td></tr><tr><td>Processor</td><td>$($CPU.Name)</td></tr><tr><td>Graphics (GPU)</td><td>$GPUName</td></tr><tr><td>Installed RAM</td><td>$RAM</td></tr></table>"

    # 3. Storage
    $SysDrive = $env:SystemDrive
    $Disks = Get-CimInstance Win32_LogicalDisk -Filter "DriveType=3" | Select-Object `
        @{Name="Drive";Expression={ if ($_.DeviceID -eq $SysDrive) { "$($_.DeviceID) ($OSName)" } else { $_.DeviceID } }}, 
        @{Name="Free Space (GB)";Expression={[math]::round($_.FreeSpace / 1GB,2)}},
        @{Name="Total Size (GB)";Expression={[math]::round($_.Size / 1GB,2)}}
    $FullContent += "<h2>Storage Health</h2>" + ($Disks | ConvertTo-Html -Fragment)

    # 4. Battery Health
    $FullContent += "<h2>Battery Health</h2>"
    try {
        $FullCap = @(Get-CimInstance -Namespace root\wmi -ClassName BatteryFullChargedCapacity -ErrorAction Stop); $DesignCap = @(Get-CimInstance -Namespace root\wmi -ClassName BatteryStaticData -ErrorAction Stop)
        if ($FullCap.Count -gt 0 -and $DesignCap.Count -gt 0) {
            $FullContent += "<table><tr><th>Battery</th><th>Design Capacity</th><th>Full Charge Capacity</th><th>Health Status</th></tr>"
            for ($i=0; $i -lt $FullCap.Count; $i++) {
                $fc = $FullCap[$i].FullChargedCapacity; $dc = $DesignCap[$i].DesignedCapacity
                $health = [math]::Round(($fc / $dc) * 100, 1)
                $color = if ($health -ge 80) { "#4CAF50" } elseif ($health -ge 50) { "#FF9800" } else { "#F44336" }
                $FullContent += "<tr><td>Battery $($i+1)</td><td>$dc mWh</td><td>$fc mWh</td><td style='color:$color; font-weight:bold;'>$health%</td></tr>"
            }
            $FullContent += "</table>"
        } else { $FullContent += "<p style='color:#888888;'>No battery detected.</p>" }
    } catch { $FullContent += "<p style='color:#888888;'>No battery detected (Desktop PC).</p>" }

    # 5. Network
    $Network = Get-NetAdapter | Where-Object Status -eq 'Up' | Select-Object Name, InterfaceDescription, MacAddress
    $FullContent += "<h2>Active Network Adapters</h2>" + ($Network | ConvertTo-Html -Fragment)

    # 6. Crash Diagnostics
    $Events = Get-WinEvent -FilterHashtable @{LogName='System'; Level=1,2; StartTime=(Get-Date).AddDays(-30)} -MaxEvents 5 -ErrorAction SilentlyContinue | Where-Object { $_.ProviderName -match "BugCheck|Kernel-Power|WER" }
    $FullContent += "<h2>Recent System Crashes (Last 30 Days)</h2>"
    if ($Events) {
        $FullContent += "<table><tr><th>Date & Time</th><th>Event ID</th><th>Source</th></tr>"
        foreach ($e in $Events) { $FullContent += "<tr><td>$($e.TimeCreated)</td><td style='color:#F44336; font-weight:bold;'>$($e.Id)</td><td>$($e.ProviderName)</td></tr>" }
        $FullContent += "</table>"
    } else { $FullContent += "<p><span style='color:#4CAF50; font-weight:bold;'>Excellent:</span> No critical crashes or Blue Screens detected recently.</p>" }

    # 7. Startup Analyzer
    $StartupItems = @()
    $HKLM = Get-ItemProperty "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
    if ($HKLM) { foreach ($prop in $HKLM.psobject.properties | Where-Object { $_.Name -notin "PSPath","PSParentPath","PSChildName","PSDrive","PSProvider" }) { $StartupItems += [PSCustomObject]@{Source="Registry (All Users)"; Name=$prop.Name; Command=$prop.Value} } }
    $HKCU = Get-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -ErrorAction SilentlyContinue
    if ($HKCU) { foreach ($prop in $HKCU.psobject.properties | Where-Object { $_.Name -notin "PSPath","PSParentPath","PSChildName","PSDrive","PSProvider" }) { $StartupItems += [PSCustomObject]@{Source="Registry (Current User)"; Name=$prop.Name; Command=$prop.Value} } }
    $FullContent += "<h2>Startup Programs (Slow Boot Analyzer)</h2>"
    if ($StartupItems.Count -gt 0) {
        $FullContent += "<table><tr><th>App Name</th><th>Command / Path</th></tr>"
        foreach ($item in $StartupItems) { $FullContent += "<tr><td style='font-weight:bold;'>$($item.Name)</td><td>$($item.Command)</td></tr>" }
        $FullContent += "</table>"
    } else { $FullContent += "<p>No third-party startup apps detected.</p>" }

    # 8. Security & BitLocker
    $FullContent += "<h2>Security & Encryption</h2>"
    try {
        $BL = Get-BitLockerVolume -MountPoint $env:SystemDrive -ErrorAction Stop
        $BLStatus = if ($BL.VolumeStatus -eq 'FullyDecrypted') { "<span style='color:#F44336; font-weight:bold;'>Decrypted (Protection OFF)</span>" } else { "<span style='color:#4CAF50; font-weight:bold;'>$($BL.VolumeStatus)</span>" }
        $FullContent += "<table><tr><th>BitLocker Drive</th><th>Encryption Status</th><th>Method</th></tr><tr><td>$($BL.MountPoint)</td><td>$BLStatus</td><td>$($BL.EncryptionMethod)</td></tr></table><br>"
    } catch { $FullContent += "<p style='color:#FF9800;'>BitLocker is not supported on this Windows edition.</p>" }
    
    $AVProducts = Get-CimInstance -Namespace root/SecurityCenter2 -ClassName AntiVirusProduct -ErrorAction SilentlyContinue
    if ($AVProducts) {
        $FullContent += "<table><tr><th>Antivirus Name</th><th>Protection Status</th><th>Signatures</th></tr>"
        foreach ($av in $AVProducts) {
            $State = $av.productState; $IsEnabled = ($State -band 0xF000) -eq 0x1000; $IsUpToDate = ($State -band 0x00F0) -eq 0
            $StatusText = if ($IsEnabled) { "<span style='color:#4CAF50; font-weight:bold;'>Enabled</span>" } else { "<span style='color:#F44336; font-weight:bold;'>Disabled</span>" }
            $UpdateText = if ($IsUpToDate) { "<span style='color:#4CAF50; font-weight:bold;'>Up to Date</span>" } else { "<span style='color:#FF9800; font-weight:bold;'>Outdated</span>" }
            $FullContent += "<tr><td>$($av.displayName)</td><td>$StatusText</td><td>$UpdateText</td></tr>"
        }
        $FullContent += "</table>"
    } else { $FullContent += "<p style='color:#F44336;'>No Antivirus products registered in Windows Security Center.</p>" }

    # 9. Software Updates
    $env:WINGET_DISABLE_PROGRESS_BAR = 1 
    $upgradeData = winget upgrade --accept-source-agreements | Out-String
    if ($upgradeData -match "No installed package found" -or $upgradeData -match "No applicable update") {
        $FullContent += "<h2>Software Updates</h2><p><span style='color:#4CAF50; font-weight:bold;'>All managed software is up to date!</span></p>"
    } elseif ($upgradeData -match "Name") {
        $cleanData = $upgradeData -replace "(?s).*?(Name\s+Id\s+Version)","`$1"
        $FullContent += "<h2>Available Software Updates</h2><pre class='log-box'>$cleanData</pre>"
    } else { $FullContent += "<h2>Software Updates</h2><pre class='log-box'>$upgradeData</pre>" }

    New-HtmlReport -Title "Ultimate System Audit Report" -Content $FullContent
}

