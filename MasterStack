function Get-QuickUpdateStatus {
    $RebootPath = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired"
    if (Test-Path $RebootPath) { return "<span style='color:#FF9800; font-weight:bold;'>Needs Restart</span> (Updates pending)" }
    try {
        $lastFix = Get-CimInstance Win32_QuickFixEngineering | Where-Object InstalledOn -ne $null | Sort-Object InstalledOn -Descending | Select-Object -First 1
        if ($lastFix) {
            $installDate = [datetime]$lastFix.InstalledOn
            $daysSince = ((Get-Date) - $installDate).Days
            if ($daysSince -le 35) { return "<span style='color:#4CAF50; font-weight:bold;'>Up to Date</span> (Last patched: $($installDate.ToShortDateString()))" } 
            else { return "<span style='color:#F44336; font-weight:bold;'>Needs Update</span> (Last patched: $($installDate.ToShortDateString()))" }
        }
    } catch { return "Status Unknown" }
    return "Status Unknown"
}

function New-HtmlReport {
    param([string]$Title, [string]$Content)
    $CSS = @"
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #222222; color: #eeeeee; padding: 30px; margin: 0; }
        .report-container { max-width: 900px; margin: 0 auto; background-color: #333333; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
        h1 { font-size: 24pt; font-weight: 300; margin-top: 0; color: #4fc3f7; border-bottom: 1px solid #555555; padding-bottom: 15px; }
        h2 { font-size: 16pt; font-weight: 400; margin-top: 30px; color: #dddddd; border-bottom: 1px dashed #555; padding-bottom: 5px; }
        table { border-collapse: collapse; width: 100%; margin-top: 15px; font-size: 11pt; }
        th { text-align: left; font-weight: 600; color: #aaaaaa; padding: 10px; border-bottom: 2px solid #555555; background-color: #2a2a2a; }
        td { padding: 10px; border-bottom: 1px solid #444444; }
        tr:nth-child(even) { background-color: #2c2c2c; }
        .log-box { font-family: 'Consolas', monospace; background-color: #111111; padding: 20px; border-radius: 5px; color: #4CAF50; line-height: 1.5; overflow-x: auto; margin-top:15px; }
        .timestamp { color: #888888; font-size: 10pt; margin-bottom: 20px; }
        .update-box { background-color: #2a2a2a; padding: 15px; border-left: 4px solid #4fc3f7; margin-top: 30px; }
    </style>
"@
    $Date = Get-Date -Format "dddd, MMMM dd, yyyy 'at' hh:mm tt"
    $UpdateStatus = Get-QuickUpdateStatus
    $HTML = @"
    <!DOCTYPE html><html><head><title>$Title</title>$CSS</head><body>
        <div class="report-container">
            <h1>$Title</h1><div class="timestamp">Report generated on $Date</div>
            $Content
            <div class="update-box"><h2 style="margin-top:0; border:none; padding:0;">Windows Update Status</h2><p style="margin-bottom:0; font-size:12pt;">$UpdateStatus</p></div>
        </div>
    </body></html>
"@
    $ReportName = $Title -replace '[^a-zA-Z0-9]', ''
    $ReportPath = "$env:TEMP\${ReportName}.html"
    $HTML | Out-File -FilePath $ReportPath -Encoding utf8 -Force
    Invoke-Item $ReportPath
}

